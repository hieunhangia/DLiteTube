<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DLiteTube.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
        xmlns:models="clr-namespace:DLiteTube.Models"
        mc:Ignorable="d"
        x:Class="DLiteTube.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="DLiteTube"
        Width="600" Height="700">
    <ScrollViewer>
        <StackPanel Margin="12" Spacing="8">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8"
                  VerticalAlignment="Top">

                <!-- TextBox with Paste button -->
                <TextBox Grid.Column="0"
                         Watermark="Nhập link youtube hoặc dán từ bộ nhớ tạm"
                         Text="{Binding SearchUrl, Mode=TwoWay}"
                         VerticalAlignment="Center">
                    <TextBox.InnerRightContent>
                        <Button Command="{Binding PasteFromClipboardCommand}"
                                Cursor="Hand"
                                Margin="3">
                            <PathIcon Width="12" Height="12"
                                      Data="M19 2h-4.18C14.4 0.84 13.3 0 12 0S9.6 0.84 9.18 2H5C3.9 2 3 2.9 3 4v16c0 1.1 0.9 2 2 2h14c1.1 0 2-0.9 2-2V4c0-1.1-0.9-2-2-2zm-7 0c0.55 0 1 0.45 1 1s-0.45 1-1 1-1-0.45-1-1 0.45-1 1-1zm7 18H5V4h2v3h10V4h2v16z" />
                        </Button>
                    </TextBox.InnerRightContent>
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}" />
                    </TextBox.KeyBindings>
                </TextBox>

                <!-- Search button -->
                <Button Grid.Column="1"
                        Command="{Binding SearchCommand}"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <PathIcon Width="12" Height="12"
                                  Margin="0,1,4,0"
                                  Data="M15.5 14h-0.79l-0.28-0.27A6.47 6.47 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-0.59 4.23-1.57l0.27 0.28v0.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" />
                        <TextBlock Text="Tìm kiếm" VerticalAlignment="Center" FontWeight="Bold" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Loading indicator -->
            <StackPanel IsVisible="{Binding IsSearching}">
                <ProgressBar IsIndeterminate="True" Height="5" />
            </StackPanel>

            <StackPanel IsVisible="{Binding HasResult}"
                        Spacing="8">
                <!-- Video information -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="5">
                    <asyncImageLoader:AdvancedImage Grid.Column="0"
                                                    Source="{Binding VideoResult.ThumbnailUrl}" />
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding VideoResult.Title}" FontWeight="Bold" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding VideoResult.Author}" />
                        <TextBlock Text="{Binding VideoResult.Duration}"
                                   IsVisible="{Binding !VideoResult.IsLiveStream}" />
                        <TextBlock Text="{Binding VideoResult.Url}" />
                    </StackPanel>
                </Grid>

                <!-- Live stream -->
                <StackPanel IsVisible="{Binding VideoResult.IsLiveStream}">
                    <Button Command="{Binding WatchLiveStreamCommand}">
                        <TextBlock Text="Xem LiveStream" />
                    </Button>
                </StackPanel>

                <!-- Normal video -->
                <StackPanel IsVisible="{Binding !VideoResult.IsLiveStream}">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="5"
                          RowDefinitions="Auto,360" RowSpacing="5">
                        <TextBlock Grid.Column="0" Grid.Row="0" Text="Video" />
                        <ScrollViewer Grid.Column="0" Grid.Row="1">
                            <ListBox
                                ItemsSource="{Binding VideoResult.VideoStreams}"
                                SelectedItem="{Binding SelectedVideoStream, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:VideoStreamInfo">
                                        <StackPanel>
                                            <TextBlock Text="{Binding VideoQuality}" />
                                            <TextBlock Text="{Binding Container}" />
                                            <TextBlock Text="{Binding Bitrate}" />
                                            <TextBlock Text="{Binding FileSizeWithBestAudio}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                        <TextBlock Grid.Column="1" Grid.Row="0" Text="Âm thanh" />
                        <ScrollViewer Grid.Column="1" Grid.Row="1">
                            <ListBox ItemsSource="{Binding VideoResult.AudioOnlyStreams}"
                                     SelectedItem="{Binding SelectedAudioOnlyStream, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:AudioOnlyStreamInfo">
                                        <StackPanel>
                                            <TextBlock Text="{Binding AudioBitrate}" />
                                            <TextBlock Text="{Binding Container}" />
                                            <TextBlock Text="{Binding AudioLanguage}" />
                                            <TextBlock Text="{Binding FileSize}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>

                    </Grid>

                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding WatchCommand}">
                            <TextBlock Text="Xem" />
                        </Button>

                        <Button Command="{Binding DownloadCommand}">
                            <TextBlock Text="Tải xuống" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>

</Window>