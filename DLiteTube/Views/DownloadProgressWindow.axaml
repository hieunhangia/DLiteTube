<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:DLiteTube.ViewModels"
        mc:Ignorable="d"
        Width="400" Height="200"
        x:Class="DLiteTube.Views.DownloadProgressWindow"
        x:DataType="viewModels:DownloadProgressViewModel"
        Title="Đang tải xuống">
    <ScrollViewer>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
            <TextBlock Text="{Binding Title}"
                       TextWrapping="Wrap" />
            <ProgressBar Value="{Binding DownloadProgress}"
                         Minimum="0" Maximum="100"
                         Height="20" Margin="0 10"
                         ShowProgressText="True"
                         IsIndeterminate="False" />
            <Button Command="{Binding CancelDownloadCommand}"
                    Cursor="Hand">
                <TextBlock Text="Hủy tải xuống" />
            </Button>
        </StackPanel>
    </ScrollViewer>
</Window>