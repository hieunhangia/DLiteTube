<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:DLiteTube.ViewModels"
        x:Class="DLiteTube.Views.SettingWindow"
        x:DataType="viewModels:SettingViewModel"
        Title="Cài đặt"
        Width="600" Height="300">
    <ScrollViewer>
        <StackPanel VerticalAlignment="Center" Margin="20" Spacing="10">
            <Grid ColumnDefinitions="150, *, Auto" ColumnSpacing="10">
                <TextBlock Grid.Column="0" Text="Đường dẫn FFmpeg: " VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding FfmpegPath}"/>
                <Button Grid.Column="2" Command="{Binding BrowseFfmpegPathCommand}">
                    <PathIcon Width="20" Height="20" 
                              Data="M20,6h-8l-2-2H4C2.9,4,2.01,4.9,2.01,6L2,18c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V8C22,6.9,21.1,6,20,6z M20,18H4V8h16V18z" />
                </Button>
            </Grid>
            <Grid ColumnDefinitions="150, *, Auto" ColumnSpacing="10">
                <TextBlock Grid.Column="0" Text="Đường dẫn tải xuống: " VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding DownloadPath}"/>
                <Button Grid.Column="2" Command="{Binding BrowseDownloadPathCommand}">
                    <PathIcon Width="20" Height="20" 
                              Data="M20,6h-8l-2-2H4C2.9,4,2.01,4.9,2.01,6L2,18c0,1.1,0.9,2,2,2h16c1.1,0,2-0.9,2-2V8C22,6.9,21.1,6,20,6z M20,18H4V8h16V18z" />
                </Button>
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Luôn hỏi đường dẫn tải xuống" VerticalAlignment="Center"/>
                <CheckBox IsChecked="{Binding AlwaysAskDownloadPath}"/>
            </StackPanel>
            
            <Button HorizontalAlignment="Right" Command="{Binding SaveSettingsCommand}">
                <TextBlock Text="Lưu cài đặt"/>
            </Button>
        </StackPanel>
    </ScrollViewer>
</Window>